{
  "version": 3,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "installDir": "${sourceDir}/install/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "windows-base",
      "hidden": true,
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "cl",
        "CMAKE_CXX_COMPILER": "cl"
      }
    },
    {
      "name": "mingw-base",
      "hidden": true,
      "inherits": "base",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-mingw-dynamic"
      }
    },
    {
      "name": "x64-debug",
      "displayName": "x64 Debug",
      "inherits": "windows-base",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
    },
    {
      "name": "x64-release",
      "displayName": "x64 Release",
      "inherits": "windows-base",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
    },
    {
      "name": "x64-relwithdebinfo",
      "displayName": "x64 RelWithDebInfo",
      "inherits": "windows-base",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "RelWithDebInfo" }
    },
    {
      "name": "mingw-debug",
      "displayName": "MinGW Debug",
      "inherits": "mingw-base",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
    },
    {
      "name": "mingw-release",
      "displayName": "MinGW Release",
      "inherits": "mingw-base",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
    },
    {
      "name": "linux-debug",
      "displayName": "Linux Debug",
      "inherits": "base",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug", "BUILD_TESTS": "ON" }
    }
  ],
  "buildPresets": [
    { "name": "x64-debug",          "configurePreset": "x64-debug" },
    { "name": "x64-release",        "configurePreset": "x64-release" },
    { "name": "x64-relwithdebinfo", "configurePreset": "x64-relwithdebinfo" },
    { "name": "mingw-debug",        "configurePreset": "mingw-debug" },
    { "name": "mingw-release",      "configurePreset": "mingw-release" },
    { "name": "linux-debug",        "configurePreset": "linux-debug" }
  ],
  "testPresets": [
    {
      "name": "x64-debug",
      "configurePreset": "x64-debug",
      "output": { "verbosity": "verbose" }
    },
    {
      "name": "mingw-debug",
      "configurePreset": "mingw-debug",
      "output": { "verbosity": "verbose" }
    },
    {
      "name": "linux-debug",
      "configurePreset": "linux-debug",
      "output": { "verbosity": "verbose" }
    }
  ]
}
